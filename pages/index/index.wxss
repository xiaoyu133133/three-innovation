/* 页面背景色 */
page {
  background-color: #f7f8fa;
  padding-bottom: 50rpx; /* 防止底部内容被TabBar遮挡 */
}

/* 轮播图样式 */
.banner-swiper {
  width: 100%;
  height: 350rpx;
}
.banner-image {
  width: 100%;
  height: 100%;
}

/* 标题样式 */
.section-title {
  padding: 20rpx 30rpx;
  font-weight: bold;
  font-size: 32rpx;
  color: #333;
  background-color: #fff;
  margin-top: 20rpx;
}

/* --- 双列商品布局 (核心) --- */
.product-container {
  display: flex;
  flex-wrap: wrap; /* 允许换行 */
  justify-content: space-between; /* 两端对齐 */
  padding: 20rpx;
}

.product-card {
  width: 48%; /* 稍微小于50%，留出空隙 */
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.product-img {
  width: 100%;
  /* 高度自动，由 widthFix 模式控制 */
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  /* 限制文字最多显示两行，多了显示省略号 */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 80rpx;
  line-height: 40rpx;
}

.product-price-row {
  margin-top: 10rpx;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #ff6700;
}

.price-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6700;
  margin-right: 10rpx;
}