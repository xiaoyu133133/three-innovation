/* 电子证书海报 (新版极简质感样式) */
.cert-poster { width: 320px; display: flex; flex-direction: column; align-items: center; }

/* ✨ 删除了背景图片，改用双层绿边的实体证书风格 */
.cert-bg { 
  background: #ffffff; 
  padding: 30px; 
  position: relative; 
  box-shadow: 0 10px 30px rgba(0,0,0,0.2); 
  border: 4px double #07c160; /* 双层绿色边框，极具权威感 */
  border-radius: 4px; /* 证书一般方正一点，所以圆角改小 */
}

/* 删除了之前的 ::before 遮罩代码，现在不需要了 */

.cert-title { font-size: 22px; font-weight: bold; color: #07c160; text-align: center; margin-bottom: 25px; letter-spacing: 2px; }
.cert-content { font-size: 14px; color: #333; line-height: 1.8; }
.cert-name { display: block; font-weight: bold; margin-bottom: 10px; }
.cert-p { display: block; margin-bottom: 10px; text-indent: 2em; }
.hl { color: #ee0a24; font-size: 16px; font-weight: bold; margin: 0 4px; }
.cert-footer { margin-top: 30px; text-align: right; }
.cert-date { font-size: 12px; color: #666; margin-bottom: 5px; }
.cert-seal { display: inline-block; color: #ee0a24; border: 2px solid #ee0a24; padding: 5px 15px; border-radius: 50%; font-weight: bold; transform: rotate(-15deg); font-family: "STKaiti", serif; }