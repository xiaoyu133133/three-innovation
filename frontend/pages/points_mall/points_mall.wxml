<view class="container">
  
  <view class="assets-header">
    <view class="assets-left">
      <text class="assets-label">当前可用积分</text>
      <text class="assets-num">{{ currentPoints }}</text>
    </view>
    <van-icon name="balance-list-o" size="24px" color="#fff" />
  </view>

  <view class="goods-list">
    <block wx:for="{{ products }}" wx:key="id">
      <view class="goods-card" bindtap="buyProduct" data-id="{{ item.id }}">
        
        <view class="goods-img-placeholder" style="background: {{ item.color }};">
          <text class="placeholder-text">{{ item.shortName }}</text>
        </view>
        
        <view class="goods-info">
          <view class="goods-name">{{ item.name }}</view>
          <view class="goods-desc">{{ item.desc }}</view>
          
          <view class="goods-bottom">
            <view class="goods-price">
              <text class="price-num">{{ item.price }}</text>
              <text class="price-unit">积分</text>
            </view>
            <view class="buy-btn">兑换</view>
          </view>
        </view>
        
      </view>
    </block>
  </view>

</view>